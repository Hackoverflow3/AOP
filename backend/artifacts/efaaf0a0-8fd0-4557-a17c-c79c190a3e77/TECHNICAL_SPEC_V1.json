  },
  "api_endpoints": [
    {
      "method": "GET",
      "path": "/calculate/{expression}",
      "description": "Performs a calculation using the provided expression.",
      "request": {
        "$ref": "#/$defs/CalculatorRequest"
      },
      "response": {
        "$ref": "#/$defs/CalculatorResponse"
      }
    },
    {
      "method": "PUT",
