    },
    "CalculatorResponse": {
      "type": "object",
      "properties": {
        "result": {"type": "number"}
      },
      "required": ["result"]
    },
    "DatabaseRequest": {
      "type": "object",
      "properties": {
        "result": {"type": "number"}
      },
      "required": ["result"]
    },
    "DatabaseResponse": {
      "type": "object",
      "properties": {
        "success": {"type": "boolean"}
      },
      "required": ["success"]
    },
    "CachingRequest": {
      "type": "object",
      "properties": {
        "expression": {"type": "string"}
      },
      "required": ["expression"]
    },
    "CachingResponse": {
      "type": "object",
      "properties": {
        "result": {"type": "number"}
      },
      "required": ["result"]
    },
    "CalculatorService": {
      "$ref": "#/$defs/CalculatorResponse"
    },
    "DatabaseService": {
      "$ref": "#/$defs/DatabaseResponse"
    },
    "CachingService": {
      "$ref": "#/$defs/CachingResponse"
    }
  },
  "components": {
    "CalculatorService": {
      "$ref": "#/$defs/CalculatorService"
    },
    "DatabaseService": {
      "$ref": "#/$defs/DatabaseService"
    },
    "CachingService": {
      "$ref": "#/$defs/CachingService"
    }
  },
